    appendMode: 0
  introBlocks:
  - text: "\uB2F9\uC2E0 \uC55E\uC5D0 \uC804\uB839\uC774 \uB098\uD0C0\uB0AC\uC2B5\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
