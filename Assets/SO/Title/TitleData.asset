--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9c9e06fd6d96b9d4e98e5263df8f96cb, type: 3}
  m_Name: TitleData
  m_EditorClassIdentifier: Assembly-CSharp::TitleData
  introBlocks:
  - "\uB2F9\uC2E0\uC740 \uBCC0\uD654\uB97C \uAC08\uB9DD\uD569\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC774
    \uC628 \uC774\uC720\uC785\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740 \uB208\uC744 \uB739\uB2C8\uB2E4."
  - "\uCE60\uD751 \uAC19\uC740 \uBC29. \uC54C \uC218 \uC5C6\uB294 \uBB34\uC5B8\uAC00(\uBCF5\uC218\uD615).
    \uD14C\uC774\uBE14.\r\n\uD14C\uC774\uBE14\uB85C \uB2E4\uAC00\uAC11\uB2C8\uB2E4."
  - "\uADF8\uB4E4\uC774 \uACF5\uBA85\uD558\uB294, \uB0B4\uBC49\uB294, \uB9D0\uD558\uB294
    \uC18C\uB9AC\uAC00 \uB4E4\uB9BD\uB2C8\uB2E4.\r\n\uADF8\uB4E4\uC774 \uCC9C\uC7A5\uC73C\uB85C
    \uC190\uC744 \uBED7\uC2B5\uB2C8\uB2E4.\r\n\uCC9C\uC7A5 \uB108\uBA38\uC758 \uC6B0\uC8FC\uC5D0\uC11C
    \uC720\uC131\uB4E4\uC744 \uC9D1\uB294 \uAC8C \uBCF4\uC785\uB2C8\uB2E4."
  - "12\uAC1C\uC758 \uC720\uC131\uC774 \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC5D0\uAC90
    12 \uD3EC\uC778\uD2B8\uAC00 \uC788\uC2B5\uB2C8\uB2E4.\r\n\uC544\uB798 \uACF5\uCC45\uC5D0
    \uC801\uD600 \uC788\uB294 \uD56D\uBAA9\uC5D0 \uC790\uC720\uB86D\uAC8C \uBD84\uBC30\uD558\uC138\uC694."
  allocateBlocks:
  - "\uD68C\uC911\uC2DC\uACC4\uAC00 \uC9F8\uAE4D\uAC70\uB9BD\uB2C8\uB2E4.\r\n\uC9F8\uAE4D\uC9F8\uAE4D\uC9F8\uAE4D\uC9F8\uAE4D\uC9F8\uAE4D.\r\n\uC9F8\uAE4D\uC9F8\uAE4D\uC9F8\uAE4D\uC9F8\uAE4D."
  - "\uC9F8\uAE4D\uC9F8\uAE4D\uC9F8\uAE4D.\r\n\uC9F8\uAE4D\uC9F8\uAE4D.\n\uC9F8\uAE4D."
  confirmBlocks:
  - "\uBD84\uBC30 \uD6C4\uC5D4 \uB3CC\uC774\uD0AC \uC218 \uC5C6\uC2B5\uB2C8\uB2E4.\n\uC774\uAC83\uC740
    \uB2F9\uC2E0\uC758 \uC548\uC804\uACFC \uBBF8\uB798\uC5D0 \uB300\uD55C \uBAA8\uB4E0
    \uAC83\uC785\uB2C8\uB2E4."
  - "\uACF5\uCC45\uC5D0\uC11C \uC885\uC774\uAC00 \uCC22\uACA8\uB098\uAC11\uB2C8\uB2E4.\n\uC8FC\uC6B0\uC2ED\uC2DC\uC624."
  - "\uC885\uC774\uC5D4 \uB2F9\uC2E0\uC774 \uB0B4\uB9B0 \uC120\uD0DD\uC774 \uC801\uD600
    \uC788\uC2B5\uB2C8\uB2E4.\n\uC54C \uC218 \uC5C6\uB294 \uBB34\uC5B8\uAC00\uAC00
    \uC801\uD600 \uC788\uC2B5\uB2C8\uB2E4.\n\uB73B\uC740 \uBAB0\uB77C\uB3C4 \uD615\uD0DC\uB294
    \uBC18\uB4DC\uC2DC \uAE30\uC5B5\uD558\uC2ED\uC2DC\uC624."
  - "\uB2F9\uC2E0\uC740 \uC9D1\uC73C\uB85C \uB3CC\uC544\uAC00\uC57C \uD569\uB2C8\uB2E4.\n\uBC18\uB4DC\uC2DC
    \uAE30\uC5B5\uD558\uC2ED\uC2DC\uC624."
