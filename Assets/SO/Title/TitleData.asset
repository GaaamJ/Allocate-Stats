  postNotebookBlocks:
  - text: "\uB2F9\uC2E0\uC5D0\uAC8C \uC804\uB839\uC774 \uB9D0\uD569\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  - text: "\uB2F9\uC2E0\uC5D0\uAC8C \uAE30\uD68C\uAC00 \uC788\uC74C\uC744 \uB9D0\uD569\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  - text: "\uB2F9\uC2E0\uC774 \uBCC0\uD654\uD560 \uC218 \uC788\uB294 \uAE30\uD68C\uC785\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  p02PreBlocks:
  - text: "\uB2F9\uC2E0 \uC55E\uC5D0\uC11C, \uC804\uB839\uC774 \uBCC4\uC744 \uC9D1\uC2B5\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  - text: "\uB2F9\uC2E0 \uC55E\uC5D0 12\uAC1C\uC758 \uBCC4\uC774 \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  p02PostBlocks:
  - text: "\uB2F9\uC2E0\uC5D0\uAC8C 12\uAC1C\uC758 \uBCC4\uC774 \uC788\uC2B5\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  - text: "\uB2F9\uC2E0\uC740 \uACF5\uCC45\uC744 \uBC14\uB77C\uBD05\uB2C8\uB2E4..."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  p02NotebookBlocks:
  - text: "\uD589\uB3D9: 12\uAC1C\uC758 \uC2A4\uD0EF\uC744 \uBD84\uBC30\uD558\uC138\uC694.\n\uD589\uB3D9:
      \uBD84\uBC30\uD558\uACE0 \uC11C\uBA85\uD558\uC138\uC694.\n\uC0AC\uACE0: \uBD84\uBC30
      \uD6C4\uC5D4 \uB3CC\uC774\uD0AC \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    channel: 2
    pauseAfter: 2
    shakeIntensity: 0
    shakeFrequency: 1
    appendMode: 0
  p03_01Blocks:
  - text: "\uB2F9\uC2E0\uC740 \uACB0\uC815\uC744 \uB0B4\uB838\uC2B5\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  - text: "\uB2F9\uC2E0\uC758 \uBBF8\uB798\uAC00 \uACB0\uC815\uB410\uC2B5\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC758
      \uC548\uC804\uC774 \uACB0\uC815\uB410\uC2B5\uB2C8\uB2E4."
    channel: 1
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  p03_02Blocks:
  - text: "\uC0AC\uACE0: \uC885\uC774\uC758 \uC9C0\uC2DC\uB97C \uB530\uB974\uC138\uC694.\n\uC0AC\uACE0:
      \uC885\uC774\uC758 \uC9C0\uC2DC\uB294 \uC774\uB8E8\uC5B4\uC9D1\uB2C8\uB2E4."
    channel: 2
    pauseAfter: 1.5
    shakeIntensity: 2
    shakeFrequency: 10
    appendMode: 0
  - text: "\uB2F9\uC2E0\uC740 \uB208\uC744 \uAC10\uC2B5\uB2C8\uB2E4."
