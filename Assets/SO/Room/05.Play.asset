  displayName: "\uC5F0\uADF9"
  phases:
  - phaseID: ENTER
    triggerCondition: 0
    triggerObjectID: 
    requiredPhaseIDs: []
    isRepeatable: 0
    requirementFailNarration: []
    onEnter:
    - "\uD770\uC0C9 \uBC29. \uB6AB\uB9B0 \uCC9C\uC7A5 \uB108\uBA38\uC758 \uD5E4\uC77C\uB85C
      \uC6B0\uC8FC.\r\n\uC6B8\uACE0 \uC6C3\uACE0 \uD654\uB0B4\uB294 \uC0AC\uB78C
      \uC544\uB2CC \uAC83\uB4E4.\r\n\uADF8\uAC83\uB4E4\uC758 \uC6B0\uC2A4\uAF5D\uC2A4\uB7EC\uC6B4
      \uC5F0\uADF9. "
    exitCondition: 0
    checkData:
      onBeforeCheck: []
      onAfterCheck: []
      stat: 0
      checkType: 0
      threshold: 0
      stat2: 0
      threshold2: 0
      onSuccess:
        narration: []
        type: 0
        targetPhaseID: 
        endingID: 
      onFailure:
        narration: []
        type: 0
        targetPhaseID: 
        endingID: 
      summaryText_success: 
      summaryText_failure: 
    outcome:
      narration:
      - "\uACE0\uB9AC\uAC00 \uB9D0\uD569\uB2C8\uB2E4."
      - "'\uC0C8\uB85C\uC6B4\uBC30\uC6B0\uAC00\uC654\uC5B4\uC0C8\uB85C\uC6B4\uBC30\uC6B0\r\n\uC6B0\uB9AC\uADF9\uB2E8\uC5D0\uC601\uC785\uD558\uACE0\uC2F6\uC740\uB370\uBCF4\uC774\uC9C0\uAC00\uC54A\uC544\r\n\uC5B4\uB514\uC788\uC9C0?\uC5B4\uB514\uC788\uC9C0?\uC5B4\uB514\uC788\uC9C0?'"
      type: 0
      targetPhaseID: PLAY
      endingID: 
    animator: {fileID: 0}
  - phaseID: PLAY
    triggerCondition: 0
    triggerObjectID: 
    requiredPhaseIDs: []
    isRepeatable: 0
    requirementFailNarration: []
    onEnter:
    - "\uD589\uB3D9: \uC0AC\uB78C \uC544\uB2CC \uAC83\uB4E4\uC744 \uAD00\uCC30\uD558\uC138\uC694.\n\uC0AC\uACE0:
      \uC0AC\uB78C \uC544\uB2CC \uAC83\uB4E4\uC758 \uD589\uB3D9\uC744 \uC774\uD574\uD558\uC138\uC694.\n\uD589\uB3D9:
      \uADF8\uAC83\uB4E4\uCC98\uB7FC \uD589\uB3D9\uD558\uC138\uC694."
    - "\uC0AC\uACE0: \uB2F9\uC2E0\uC744 \uC78A\uC9C0 \uB9C8\uC138\uC694."
    exitCondition: 1
    checkData:
      onBeforeCheck:
      - "\uB2F9\uC2E0\uC740 \uC6C3\uB294 \uAC00\uBA74\uC744 \uC4F4 \uC5EC\uC790\uB97C
        \uBD05\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740 \uD654\uB09C \uAC00\uBA74\uC744
        \uC4F4 \uC544\uC774\uB97C \uBD05\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740 \uC6B0\uB294
        \uAC00\uBA74\uC744 \uC4F4 \uB0A8\uC790\uB97C \uBD05\uB2C8\uB2E4."
      onAfterCheck:
      - "\uB2F9\uC2E0\uC740 \uADF8\uAC83\uB4E4\uC774 \uD558\uB294 \uAC83\uC744 \uC774\uD574\uD558\uB824
        \uB178\uB825\uD569\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC740 \uADF8\uAC83\uB4E4\uC774
        \uD558\uB294 \uAC83\uC744 \uB530\uB77C\uD574\uBD05\uB2C8\uB2E4."
      stat: 3
      checkType: 3
      threshold: 3
      stat2: 0
      threshold2: 1
      onSuccess:
        narration:
        - "\uB2F9\uC2E0\uC758 \uC5F0\uADF9\uC740 \uADF8\uAC83\uB4E4\uC758 \uAE30\uC900\uC5D0
          \uBBF8\uCE58\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC758
          \uC5F0\uADF9\uC744 \uADF8\uAC83\uB4E4\uC774 \uB208\uCE58\uCC58\uC2B5\uB2C8\uB2E4."
        - "\uB2F9\uC2E0\uC5D0\uAC8C \uADF8\uAC83\uB4E4\uC774 \uB2EC\uB824\uB4ED\uB2C8\uB2E4."
        - "\uB2F9\uC2E0\uC758 \uD314\uC5D0 \uC2E4\uC774 \uBB36\uC774\uACE0 \uC5BC\uAD74\uC5D0
          \uAC00\uBA74\uC774 \uC50C\uC6CC\uC9D1\uB2C8\uB2E4."
        type: 0
        targetPhaseID: LUK
        endingID: "\uBA54\uC18C\uB4DC \uC5F0\uAE30"
      onFailure:
        narration: []
        type: 4
        targetPhaseID: 
        endingID: "\uBA54\uC18C\uB4DC \uC5F0"
      summaryText_success: "\uB2F9\uC2E0\uC740 \uC0AC\uB78C\uC774 \uD574\uC120 \uC548
        \uB418\uB294 \uC5F0\uADF9\uC5D0 \uCC38\uC5EC\uD588\uC2B5\uB2C8\uB2E4."
      summaryText_failure: "\uB2F9\uC2E0\uC740 \uC778\uAC04\uB2E4\uC6B4 \uD589\uB3D9\uC744
        \uBCF4\uC600\uC2B5\uB2C8\uB2E4."
    outcome:
      narration: []
      type: 0
      targetPhaseID: 
      endingID: 
    animator: {fileID: 0}
  - phaseID: LUK
    triggerCondition: 2
    triggerObjectID: 
    requiredPhaseIDs: []
    isRepeatable: 0
    requirementFailNarration: []
    onEnter:
    - "\uD589\uB3D9: \uB2F9\uC2E0\uC758 \uD589\uB3D9\uC774 \uADF8\uAC83\uB4E4\uACFC
      \uC720\uC0AC\uD558\uAE38 \uAE30\uB3C4\uD558\uC138\uC694.\r\n\uD589\uB3D9: \uCC9C\uCC9C\uD788
      \uBB38\uC73C\uB85C \uB2E4\uAC00\uAC00\uC138\uC694."
    exitCondition: 1
    checkData:
      onBeforeCheck:
      - "\uB2F9\uC2E0\uC740 \uC5F0\uADF9\uC744 \uACC4\uC18D\uD558\uBA70 \uBB38\uC73C\uB85C
        \uB2E4\uAC00\uAC11\uB2C8\uB2E4."
      onAfterCheck:
      - "\uB2F9\uC2E0\uC740 \uB208\uC54C\uC744 \uAD74\uB824 \uBB38\uC744 \uCC3E\uC2B5\uB2C8\uB2E4."
      stat: 4
      checkType: 3
      threshold: 2
      stat2: 0
      threshold2: 2
      onSuccess:
        narration:
        - "\uB2F9\uC2E0\uC740 \uAC78\uB9AC\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC740
          \uBB38 \uC55E\uC5D0 \uC12D\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC758 \uB4F1 \uB4A4\uC5D0\uC11C
          \uADF8\uAC83\uB4E4\uC774 \u25A0\u25A0\uD558\uB294 \uAC8C \uB290\uAEF4\uC9D1\uB2C8\uB2E4."
        - "\uB2F9\uC2E0\uC740 \uBB38\uACE0\uB9AC\uB97C \uC7A1\uC2B5\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740
          \uBB38\uACE0\uB9AC\uB97C \uB3CC\uB9BD\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740
          \uBB38\uACE0\uB9AC\uB97C \uB2F9\uAE41\uB2C8\uB2E4."
        - "\uB2F9\uC2E0\uC740 \uBB38\uC5D0 \uB4E4\uC5B4\uAC11\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740
          \uB208\uC744 \uAC10\uC2B5\uB2C8\uB2E4."
        - "\uB2F9\uC2E0\uC740 \uB2E4\uC74C \uBC29\uC73C\uB85C \uB098\uC544\uAC11\uB2C8\uB2E4."
        type: 2
        targetPhaseID: 
        endingID: 
      onFailure:
        narration:
        - "\uB2F9\uC2E0\uC774 \uBC84\uD2F0\uC9C0 \uBABB\uD588\uB4E0, \uC6B4\uC774
          \uC5C6\uC5C8\uB4E0 \uB2F9\uC2E0\uC758 \uC815\uCCB4\uAC00 \uB4E4\uD1B5\uB0AC\uC2B5\uB2C8\uB2E4."
        - "\uB2F9\uC2E0\uC5D0\uAC8C \uADF8\uAC83\uB4E4\uC774 \uB2EC\uB824\uB4ED\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC758
          \uD314\uC5D0 \uC2E4\uC774 \uBB36\uC774\uACE0 \uC5BC\uAD74\uC5D0 \uAC00\uBA74\uC774
          \uC50C\uC6CC\uC9D1\uB2C8\uB2E4."
        type: 4
        targetPhaseID: 
        endingID: "\uBA54\uC18C\uB4DC \uC5F0\uAE30"
      summaryText_success: "\uB2F9\uC2E0\uC740 \uB2F9\uC2E0\uC744 \uC78A\uC9C0 \uC54A\uACE0
        \uB098\uC544\uAC14\uC2B5\uB2C8\uB2E4."
      summaryText_failure: "\uB2F9\uC2E0\uC740 \uACE0\uB9AC\uC758 \uC77C\uBD80\uBD84\uC774
        \uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    outcome:
      narration: []
      type: 0
      targetPhaseID: 
      endingID: 
    animator: {fileID: 0}
