        type: 4
        targetPhaseID: 
        endingID: "\uC0AC\uB9DD"
      summaryText_success: "\uB2F9\uC2E0\uC740 \uAD34\uBB3C\uB85C\uBD80\uD130 \uB3C4\uB9DD\uCCE4\uC2B5\uB2C8\uB2E4."
      summaryText_failure: "\uB2F9\uC2E0\uC740 \uD759\uC774 \uB418\uC5B4 \uC0DD\uBA85\uC744
