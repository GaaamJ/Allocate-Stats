      onAfterCheck:
      - "\uB2F9\uC2E0 \uC55E\uC5D0 \uBB38\uC774 \uBCF4\uC774\uAE30 \uC2DC\uC791\uD569\uB2C8\uB2E4."
      stat: 1
      checkType: 1
      threshold: 1
      stat2: 0
      threshold2: 0
      onSuccess:
        narration:
        - "\uB2F9\uC2E0\uC740 \uAD34\uBB3C\uC758 \uACF5\uACA9\uC744 \uBB34\uC0AC\uD788
