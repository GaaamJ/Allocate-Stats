        type: 2
        targetPhaseID: 
        endingID: 
      onFailure:
        narration:
        - "\uB2F9\uC2E0\uC774 \uBB38\uC5D0 \uB2E4\uAC00\uAC00\uAE30 \uC804 \uAD34\uBB3C\uC774
          \uB2F9\uC2E0\uC744 \uB9C9\uC544\uC130\uC2B5\uB2C8\uB2E4."
        - "\uB2F9\uC2E0\uC740 \uAD34\uBB3C\uC5D0 \uC758\uD574 \u25A0\u25A0\uD574
