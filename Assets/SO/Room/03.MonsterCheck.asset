  m_Name: 03.MonsterCheck
  m_EditorClassIdentifier: Assembly-CSharp::RoomData
  roomID: MONSTER
  displayName: "\uAD34\uBB3C"
  phases:
  - phaseID: ENTER
    triggerCondition: 0
    triggerObjectID: 
    requiredPhaseIDs: []
    isRepeatable: 0
    requirementFailNarration: []
    onEnter:
    - "\uD770\uC0C9 \uBC29. \uB6AB\uB9B0 \uCC9C\uC7A5 \uB108\uBA38\uC758 \uBD89\uC740
      \uC6B0\uC8FC.\r\n\uC54C \uC218 \uC5C6\uB294 \uAD34\uBB3C. \uBB38 \uD558\uB098.\r\n\uB2F9\uC2E0
      \uC55E\uC758 \uCE7C \uD558\uB098."
    exitCondition: 0
    checkData:
      onBeforeCheck: []
      onAfterCheck: []
      stat: 0
      checkType: 0
      threshold: 0
      stat2: 0
      threshold2: 0
      onSuccess:
        narration: []
        type: 0
        targetPhaseID: 
        endingID: 
      onFailure:
        narration: []
        type: 0
        targetPhaseID: 
        endingID: 
      summaryText_success: 
      summaryText_failure: 
    outcome:
      narration:
      - "\uCC3D\uACFC \uBC29\uD328\uAC00 \uB9D0\uD569\uB2C8\uB2E4."
      - "O \uBAA9\uC228\uC744 \uAC74 \uC804\uD22C\uB97C \u2191 \uCE58\uB974\uACE0
        \r\nO \uADF8\uC5D0 \uC751\uD558\uB294 \uBCF4\uC0C1\uC744 \u2191 \uBC1B\uC544\uB77C."
      - "\uB2F9\uC2E0\uC740 \uCE7C\uC744 \uC8FC\uC6E0\uC2B5\uB2C8\uB2E4."
      type: 1
      targetPhaseID: 
      endingID: 
    animator: {fileID: 0}
  - phaseID: MONSTER
    triggerCondition: 1
    triggerObjectID: (Test)Monster
    requiredPhaseIDs: []
    isRepeatable: 0
    requirementFailNarration: []
    onEnter:
    - "\uD589\uB3D9: \uCE7C\uC744 \uB4DC\uC138\uC694.\r\n\uD589\uB3D9: \uB0B4\uB2EC\uB824\uC11C
      \uCE7C\uC744 \uAD34\uBB3C\uC758 \u25A0\u25A0\uC5D0 \uCC14\uB7EC\uC11C \u25A0\u25A0\uD558\uC138\uC694.\r\n\uD589\uB3D9:
      \uADF8\uAC83\uC774 \uBA48\uCD9C \uB54C\uAE4C\uC9C0 \uBC18\uBCF5\uD558\uC138\uC694."
    exitCondition: 1
    checkData:
      onBeforeCheck:
      - "\uB2F9\uC2E0\uC740 \uCE7C\uC744 \uB4ED\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740
        \uAD34\uBB3C\uC5D0\uAC8C \uB2EC\uB824\uB4ED\uB2C8\uB2E4."
      onAfterCheck: []
      stat: 0
      checkType: 0
      threshold: 3
      stat2: 0
      threshold2: 0
      onSuccess:
        narration:
        - "\uB2F9\uC2E0\uC740 \uAD34\uBB3C\uC758 \u25A0\u25A0\uC5D0 \uCE7C\uC744
          \uBC15\uC544\uC11C \u25A0\u25A0\uD588\uC2B5\uB2C8\uB2E4."
        type: 1
        targetPhaseID: 
        endingID: 
      onFailure:
        narration:
        - "\uB2F9\uC2E0\uC758 \uCE7C\uC740 \uAD34\uBB3C\uC758 \u25A0\u25A0\uC5D0
          \uBC15\uD788\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4."
        type: 0
        targetPhaseID: RUN
        endingID: 
      summaryText_success: "\uB2F9\uC2E0\uC740 \uAD34\uBB3C\uC744 \uC4F0\uB824\uB728\uB838\uC2B5\uB2C8\uB2E4."
      summaryText_failure: "\uB2F9\uC2E0\uC740 \uAD34\uBB3C\uC744 \uC4F0\uB7EC\uB728\uB9AC\uC9C0
        \uBABB\uD588\uC2B5\uB2C8\uB2E4."
