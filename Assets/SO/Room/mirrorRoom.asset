  displayName: "\uAC70\uC6B8"
  entryNarration: "\uC2DC\uC57C: \uAC70\uC6B8 \uBC29, \uB6AB\uB9B0 \uCC9C\uC7A5,
    \uBB34\uC218\uD55C \uBCC4\uBC14\uB2E4\uC758 \uC6B0\uC8FC.\n\uAC70\uC6B8\uC5D0
    \uB2F9\uC2E0\uC774 \uBE44\uCE69\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC774 \uBB34\uC218\uD574\uC9D1\uB2C8\uB2E4."
  steps:
  - narration: "\uC778\uC2DD: \uB2E4\uB984\uC744 \uCC3E\uC544\uB0B4\uC138\uC694."
    stat: 2
    checkType: 0
    threshold: 2
    onSuccess:
      type: 3
      nextStepIndex: 1
      narration: "\uC778\uC2DD: \uB4A4\uC9D1\uD78C \uAC83\uC744 \uCC3E\uC544\uB0C5\uB2C8\uB2E4.\n\uC67C\uCABD\uC774
        \uC624\uB978\uCABD.\n\uC704\uAC00 \uC544\uB798."
    onFailure:
      type: 1
      nextStepIndex: -1
      narration: "\uB2F9\uC2E0\uC758 \uC790\uB9AC\uB85C \uB3CC\uC544\uAC14\uC2B5\uB2C8\uB2E4."
  - narration: "\uD589\uB3D9: \uC8FC\uBA39\uC744 \uC950\uC5B4\n\uD589\uB3D9: \uB0B4\uB9AC\uCCD0\n\uD589\uB3D9:
      \uBD80\uC234"
    stat: 0
    checkType: 0
    threshold: 2
    onSuccess:
      type: 3
      nextStepIndex: 2
      narration: "\uC190\uC5D0 \uC720\uB9AC\uAC00 \uBC15\uD614\uC2B5\uB2C8\uB2E4.\n\uAC70\uC6B8
        \uC548\uC73C\uB85C \uB4E4\uC5B4\uAC00 \uB208\uC744 \uAC10\uC73C\uC138\uC694."
    onFailure:
      type: 1
      nextStepIndex: -1
      narration: "\uBD80\uC218\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.\n\uB4A4\uC9D1\uD78C
        \uAC83\uC774 \uB2E4\uAC00\uC635\uB2C8\uB2E4.\n\uB4A4\uC9D1\uD788\uC9C0 \uC54A\uC740
        \uAC83\uC774 \uB4A4\uC9D1\uD78C \uAC83\uC73C\uB85C."
  - narration: "\uAE30\uB3C4\uD558\uC138\uC694."
