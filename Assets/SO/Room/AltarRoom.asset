  m_Script: {fileID: 11500000, guid: 3c094e56c3e99be4a86edb93c579ae4f, type: 3}
  m_Name: AltarRoom
  m_EditorClassIdentifier: Assembly-CSharp::RoomData
  roomID: Altar
  displayName: "\uC81C\uB2E8"
  entryNarration: "\uC2DC\uC57C: \uD54F\uBE5B \uBE44\uB2E8\uC774 \uC62C\uB824\uC838
    \uC788\uB294 \uC81C\uB2E8.\n\uC2DC\uC57C: \uCD1B\uBD88 \uB450 \uAC1C, \uCC45
    \uD55C \uAD8C.\n\uC2DC\uC57C: \uC5B4\uB9B0 \uC591 \uD558\uB098."
  steps:
  - narration: "\uC0AC\uACE0: \uCC45\uC744 \uC77D\uC73C\uC138\uC694. \uC774\uD574\uD558\uC138\uC694.\n\uC0AC\uACE0:
      \uCC45\uC744 \uD3BC\uCE58\uC790 \uBA38\uB9AC\uC5D0 \uC815\uBCF4\uAC00 \uC785\uB825\uB429\uB2C8\uB2E4."
    stat: 3
    checkType: 0
    threshold: 3
    onSuccess:
      type: 3
      nextStepIndex: 1
      narration: "\uB2F9\uC2E0\uC740 \uC54C \uC218 \uC5C6\uB294 \uC758\uC2DD\uC758
        \uBC29\uBC95\uC744 \uC54C\uC544\uB0C5\uB2C8\uB2E4."
    onFailure:
      type: 0
      nextStepIndex: -1
      narration: "\uB2F9\uC2E0\uC740 \uC774\uD574\uD558\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.\n\uC778\uAC04\uC758
        \uB450\uB1CC\uB860 \uC774\uD574\uD560 \uC218 \uC5C6\uC5C8\uC2B5\uB2C8\uB2E4."
  - narration: "\uC2DC\uC57C: \uC5B4\uB9B0 \uC591 \uD558\uB098\n\uD589\uB3D9: \uC7A1\uC544\n\uD589\uB3D9:
      \uCE7C\uB85C \uCC14\uB7EC"
    stat: 0
    checkType: 0
    threshold: 2
    onSuccess:
      type: 3
      nextStepIndex: 2
      narration: "\uAE30\uB3C4\uD558\uC138\uC694.\n\uC22D\uBC30\uD558\uC138\uC694.\n\uAE30\uB3C4\uD558\uC138\uC694."
    onFailure:
      type: 0
      nextStepIndex: -1
      narration: "\uB3C4\uB9DD\uCCD0"
  - narration: "\uB208\uC744 \uAC10\uC73C\uC138\uC694.\n\uAE30\uB3C4\uD558\uC138\uC694.\n\uAC04\uC808\uD558\uAC8C
      \uAE30\uB3C4\uD558\uC138\uC694."
    stat: 4
    checkType: 2
    threshold: 2
    onSuccess:
      type: 2
      nextStepIndex: -1
      narration: "\uC62C\uBC14\uB978 \uC18C\uC6D0\uC744 \uBE4C\uC5C8\uC2B5\uB2C8\uB2E4.\n"
    onFailure:
      type: 0
      nextStepIndex: -1
      narration: "\uC54C \uC218 \uC5C6\uB294 \uBB34\uC5B8\uAC00. \uC778\uC2DD\uB418\uC9C0
        \uC54A\uB294 \uBB34\uC5B8\uAC00.\n\uC81C\uB2E8\uC758 \uC81C\uBB3C\uC744 \uBC1B\uC544\uB4E4\uC774\uC9C0
        \uC54A\uC2B5\uB2C8\uB2E4.\n\uD589\uB3D9: \uBB38\uACE0\uB9AC\uB97C \uC7A1\uC544
        \uB3CC\uB824 \uC5F4\uC5B4"
  canEscape: 1
