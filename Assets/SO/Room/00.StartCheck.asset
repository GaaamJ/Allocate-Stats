  - phaseID: PAPER
    triggerCondition: 1
    triggerObjectID: (Test)Paper
    requiredPhaseIDs: []
    requiredSuccessPhaseIDs: []
    isRepeatable: 0
    requirementFailNarration: []
    onEnter:
    - "\uD589\uB3D9: \uC885\uC774\uB97C \uC9D1\uC5B4\uB4DC\uC138\uC694.\r\n\uD589\uB3D9:
      \uC885\uC774\uB97C \uD3BC\uCE58\uC138\uC694."
    exitCondition: 1
    checkData:
      onBeforeCheck:
      - "\uB2F9\uC2E0\uC740 \uC885\uC774\uB97C \uD3BC\uCE69\uB2C8\uB2E4."
      onAfterCheck:
      - "\uB2F9\uC2E0\uC740 \uC885\uC774\uC5D0 \uC801\uD78C \uAC83\uC744 \uBD05\uB2C8\uB2E4."
      stat: 2
      checkType: 0
      threshold: 0
      stat2: 0
      threshold2: 0
      onSuccess:
        narration:
        - "O \uBB38\uC744 + \uACE0\uB974\uAC70\uB77C"
        type: 1
        targetPhaseID: 
        endingID: 
      onFailure:
        narration:
        - "\uC544\uBB34\uAC83\uB3C4 \uC778\uC9C0\uD558\uC9C0 \uBABB\uD558\uB294 \uC790.\n\uAC8C\uC784\uC744
          \uD558\uC9C0 \uBABB\uD558\uB294 \uC6B0\uB454\uD55C \uC790."
        type: 4
        targetPhaseID: 
        endingID: "\uBD88\uAC00"
      summaryText_success: "\uB2F9\uC2E0\uC740 \uC2ED\uC790\uB3D9\uADF8\uB77C\uBBF8\uC758
        \uC885\uC774\uB97C \uD3BC\uCCE4\uC2B5\uB2C8\uB2E4."
      summaryText_failure: "\uD574\uCEE4 \uB140\uC11D. \uD310\uC744 \uB4A4\uC9D1\uB294
        \uB140\uC11D\uB4E4."
    outcome:
      narration: []
      type: 1
      targetPhaseID: 
      endingID: 
    animator: {fileID: 0}
