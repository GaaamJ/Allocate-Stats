      \uC885\uC774 \uD55C \uC7A5.\n\uD0C1\uC790 \uB108\uBA38\uC758 \uBB38 \uD558\uB098."
    - "\uC2ED\uC790 \uB3D9\uADF8\uB77C\uBBF8\uAC00 \uB9D0\uD569\uB2C8\uB2E4."
    - "O \uB098\uC758 + \uC0AC\uB791\uC2A4\uB7EC\uC6B4 O \uC544\uC774\uC5D0\uAC8C
      + \uAE30\uD68C\uB97C."
    exitCondition: 0
    checkData:
      onBeforeCheck: []
      onAfterCheck: []
      stat: 0
      checkType: 0
      threshold: 0
      stat2: 0
      threshold2: 0
