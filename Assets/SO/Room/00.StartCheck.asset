  - phaseID: Paper
    triggerCondition: 1
    triggerObjectID: 
    requiredPhaseIDs: []
    isRepeatable: 0
    requirementFailNarration: []
    onEnter:
    - "\uB2F9\uC2E0\uC740 \uC885\uC774\uB97C \uC9D1\uC5B4\uB4ED\uB2C8\uB2E4."
    exitCondition: 1
    checkData:
      onBeforeCheck:
      - "\uB2F9\uC2E0\uC740 \uC885\uC774\uB97C \uD3BC\uCE69\uB2C8\uB2E4."
      onAfterCheck: []
      stat: 2
      checkType: 0
      threshold: 0
      stat2: 0
      threshold2: 0
      onSuccess:
        narration:
        - "\uB2F9\uC2E0\uC740 \uC885\uC774\uC5D0 \uC801\uD78C \uAC83\uC744 \uC774\uD574\uD569\uB2C8\uB2E4."
        - "\uD589\uB3D9: \uBB38\uC744 \uACE0\uB974\uC138\uC694.\n\uD589\uB3D9: \uBB38\uACE0\uB9AC\uB97C
          \uC7A1\uC73C\uC138\uC694.\n\uD589\uB3D9: \uBB38\uACE0\uB9AC\uB97C \uB3CC\uB9AC\uC138\uC694."
        - "\uD589\uB3D9: \uBB38\uACE0\uB9AC\uB97C \uB2F9\uAE30\uC138\uC694.\n\uD589\uB3D9:
          \uB208\uC744 \uAC10\uACE0 \uB4E4\uC5B4\uAC00\uC138\uC694.\n\uD589\uB3D9:
          \uC5B4\uBA38\uB2C8\uAED8 \uAE30\uB3C4\uD558\uC138\uC694."
        type: 1
        targetPhaseID: 
        endingID: 
      onFailure:
        narration:
        - "\uC544\uBB34\uAC83\uB3C4 \uC778\uC9C0\uD558\uC9C0 \uBABB\uD558\uB294 \uC790.\n\uAC8C\uC784\uC744
          \uD558\uC9C0 \uBABB\uD558\uB294 \uC6B0\uB454\uD55C \uC790."
        type: 4
        targetPhaseID: 
        endingID: "\uD574\uCEE4 \uB140\uC11D. \uD310\uC744 \uB4A4\uC9D1\uB294 \uB140\uC11D\uB4E4."
      summaryText_success: "\uB2F9\uC2E0\uC740 \uC2DC\uC791\uC5D0\uC11C \uC885\uC774\uB97C
        \uD3BC\uCE58\uACE0 \uC774\uD574\uD588\uC2B5\uB2C8\uB2E4."
      summaryText_failure: 
